generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum OrderStatus {
  draft
  pending
  paid
  cancelled
  refunded
}

model Category {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  products          Product[]
  productCategories ProductCategory[]

  @@index([isActive], map: "categories_active_idx")
  @@map("categories")
}

model Product {
  id          String @id @default(uuid()) @db.Uuid
  categoryId  String @map("category_id") @db.Uuid
  name        String
  slug        String @unique
  description String @default("")

  /// Integer cents per gram (avoid floating-point).
  priceCentsPerGram Int    @map("price_cents_per_gram")
  currency          String @default("EUR")

  /// Stock available for sale, in grams (integer array).
  availableGrams   Int[]  @default([]) @map("available_grams")
  recommendedGrams Int?   @map("recommended_grams")

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  category   Category       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  images     ProductImage[]
  orderItems OrderItem[]

  // Optional for future multi-category
  categories ProductCategory[]

  @@index([categoryId], map: "products_category_idx")
  @@index([isActive], map: "products_active_idx")
  @@map("products")
}

model ProductImage {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @map("product_id") @db.Uuid
  url       String
  alt       String   @default("")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId], map: "product_images_product_idx")
  @@map("product_images")
}

model Coupon {
  code       String   @id
  percentOff Int      @map("percent_off") // 0..100
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  orders Order[]

  @@index([isActive], map: "coupons_active_idx")
  @@index([code], map: "coupons_code_idx")
  @@map("coupons")
}

model Order {
  id          String      @id @default(uuid()) @db.Uuid
  orderNumber String      @unique @map("order_number")
  status      OrderStatus @default(pending)

  couponCode      String? @map("coupon_code")
  discountPercent Int     @default(0) @map("discount_percent")

  subtotalCents Int    @map("subtotal_cents")
  discountCents Int    @default(0) @map("discount_cents")
  totalCents    Int    @map("total_cents")
  currency      String @default("EUR")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  coupon Coupon?     @relation(fields: [couponCode], references: [code], onDelete: SetNull)
  items  OrderItem[]

  @@index([status], map: "orders_status_idx")
  @@index([createdAt], map: "orders_created_idx")
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(uuid()) @db.Uuid
  orderId   String  @map("order_id") @db.Uuid
  productId String? @map("product_id") @db.Uuid

  // snapshots
  productName           String   @map("product_name")
  unitPriceCentsPerGram Int      @map("unit_price_cents_per_gram")
  grams                 Int
  quantity              Int      @default(1)
  lineTotalCents        Int      @map("line_total_cents")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId], map: "order_items_order_idx")
  @@index([productId], map: "order_items_product_idx")
  @@map("order_items")
}

model ProductCategory {
  productId  String @map("product_id") @db.Uuid
  categoryId String @map("category_id") @db.Uuid

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId], map: "product_categories_pk")
  @@map("product_categories")
}
